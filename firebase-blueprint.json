{
  "entities": {
    "products": {
      "title": "Product",
      "description": "A product in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product" },
        "brand": { "type": "string", "enum": ["Avon", "Inuka", "Avroy Shlain"], "description": "The brand of the product" },
        "category": { "type": "string", "description": "The category of the product" },
        "quantity": { "type": "number", "description": "The quantity in stock" },
        "buying_price": { "type": "number", "description": "The price at which the product was bought" },
        "selling_price": { "type": "number", "description": "The price at which the product is sold" },
        "supplier_name": { "type": "string", "description": "The name of the supplier" },
        "batch_number": { "type": "string", "description": "The batch number of the product" },
        "expiry_date": { "type": "string", "description": "The expiry date of the product" },
        "arrival_date": { "type": "string", "description": "The arrival date of the product" },
        "image_url": { "type": "string", "description": "The URL of the product image (can be base64)" },
        "low_stock_threshold": { "type": "number", "description": "The threshold for low stock notification" },
        "uid": { "type": "string", "description": "The user ID who owns this product" }
      },
      "required": ["name", "brand", "category", "quantity", "buying_price", "selling_price", "uid"]
    },
    "users": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The display name of the user" },
        "email": { "type": "string", "description": "The email of the user" },
        "role": { "type": "string", "enum": ["admin", "assistant", "viewer"], "description": "The role of the user" },
        "uid": { "type": "string", "description": "The unique ID of the user" }
      },
      "required": ["email", "role", "uid"]
    },
    "customers": {
      "title": "Customer",
      "description": "A customer of the business",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the customer" },
        "phone": { "type": "string", "description": "The phone number of the customer" },
        "email": { "type": "string", "description": "The email of the customer" },
        "address": { "type": "string", "description": "The address of the customer" },
        "category": { "type": "string", "description": "The category of the customer" },
        "uid": { "type": "string", "description": "The user ID who owns this customer" }
      },
      "required": ["name", "phone", "category", "uid"]
    },
    "sales": {
      "title": "Sale",
      "description": "A sale record",
      "type": "object",
      "properties": {
        "customer_id": { "type": "string", "description": "The ID of the customer" },
        "total_amount": { "type": "number", "description": "The total amount of the sale" },
        "total_profit": { "type": "number", "description": "The total profit of the sale" },
        "payment_method": { "type": "string", "description": "The payment method used" },
        "items": {
          "type": "array",
          "description": "The items included in the sale"
        },
        "uid": { "type": "string", "description": "The user ID who owns this sale" }
      },
      "required": ["customer_id", "total_amount", "total_profit", "payment_method", "uid"]
    },
    "notifications": {
      "title": "Notification",
      "description": "A notification for the user",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "The type of notification" },
        "message": { "type": "string", "description": "The notification message" },
        "is_read": { "type": "number", "description": "Whether the notification has been read (0 or 1)" },
        "uid": { "type": "string", "description": "The user ID who owns this notification" }
      },
      "required": ["type", "message", "is_read", "uid"]
    },
    "social_posts": {
      "title": "Social Post",
      "description": "A social media post record",
      "type": "object",
      "properties": {
        "product_id": { "type": "string", "description": "The ID of the product" },
        "platform": { "type": "string", "description": "The social media platform" },
        "caption": { "type": "string", "description": "The post caption" },
        "status": { "type": "string", "enum": ["posted", "scheduled"], "description": "The status of the post" },
        "uid": { "type": "string", "description": "The user ID who owns this post" }
      },
      "required": ["product_id", "platform", "caption", "status", "uid"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "products",
      "description": "Collection of products"
    },
    "/users/{userId}": {
      "schema": "users",
      "description": "Collection of users"
    },
    "/customers/{customerId}": {
      "schema": "customers",
      "description": "Collection of customers"
    },
    "/sales/{saleId}": {
      "schema": "sales",
      "description": "Collection of sales"
    },
    "/notifications/{notificationId}": {
      "schema": "notifications",
      "description": "Collection of notifications"
    },
    "/social_posts/{postId}": {
      "schema": "social_posts",
      "description": "Collection of social posts"
    }
  }
}
